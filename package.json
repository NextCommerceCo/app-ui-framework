{
  "name": "app-design-system",
  "version": "latest",
  "description": "NEXT Commerce Design System",
  "main": "index.js",
  "scripts": {
    "scss": "npx sass src/scss/main.scss dist/css/main.css --load-path=node_modules --load-path=src/scss",
    "scss:docs": "npx sass docs/assets/css/main.scss docs/assets/css/main.css --load-path=node_modules --load-path=src/scss --load-path=docs/_sass --style=compressed",
    "dev": "npm run scss:docs && npx @11ty/eleventy --serve",
    "build": "npm run scss:docs && npx @11ty/eleventy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/29next/app-design-system.git"
  },
  "author": "29 Next",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/29next/app-design-system/issues"
  },
  "homepage": "https://github.com/29next/app-design-system#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "gulp-concat": "^2.6.1",
    "gulp-cssnano": "^2.1.3",
    "gulp-sass": "^5.1.0",
    "node-sass": "^8.0.0",
    "sass": "^1.71.1",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.34.0",
    "bootstrap": "^5.3.3",
    "gulp": "^4.0.2",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-uglify": "^3.0.2"
  }
}
